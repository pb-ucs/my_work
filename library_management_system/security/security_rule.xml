<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="library_member_rule_admin" model="ir.rule">
        <field name="name">Library Member: Admin </field>
        <field name="model_id" ref="model_library_member"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('library_management_system.group_lms_admin'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="False"/>
    </record>

     <record id="library_member_rule_user" model="ir.rule">
        <field name="name">Library Member: User </field>
        <field name="model_id" ref="model_library_member"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('library_management_system.group_lms_user'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="False"/>
    </record>
</odoo>
