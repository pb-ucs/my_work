<?xml version="1.0" encoding="UTF-8"?>

 <odoo>

    <record id="wizard_member_detail_form" model="ir.ui.view">
        <field name="name">member.detail.form</field>
        <field name="model">member.detail</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                       <field name='email_from' />
                       <field name='email_to' />
                       <field name='email_subject' />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_member_detail" model="ir.actions.act_window">
        <field name="name">details</field>
        <field name="res_model">member.detail</field>
        <field name="view_mode">form</field>
        <field name='target'>new</field>
    </record>
</odoo>
