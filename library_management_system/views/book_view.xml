    <record id="action_mark_as_create" model="ir.actions.server">
        <field name="name">create</field>
        <field name="model_id" ref="model_library_book"/>
        <field name="binding_model_id" ref="model_library_book"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            for records in records:
                record.action_create()
        </field>
    </record>

    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Library Books" >
                <field name="name" />
                <field name="author"/>
                <field name="publisher"/>
                <field name="category"/>
                <field name="ISBN"/>
                <field name="price" />
                <field 
                    name="status" 
                    decoration-success='status == "done"' 
                    decoration-danger='status == "progress"'
                    decoration-info='status == "start"'/>

            </list>
        </field>
    </record>
    
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field 
                        name='status' 
                        widget='statusbar' />

                    <button 
                        name="action_draft"
                        type="object"
                        string="draft"
                        class = 'btn-primary'
                        invisible="status == 'Start'"/>

                    <button 
                        name = 'action_confirmed' 
                        type = 'object' 
                        string = 'confirmed' 
                        class = 'btn-primary'
                        invisible="status == 'Draft'"/>

                    <button 
                        name = 'action_cancel' 
                        type = 'object' 
                        string = 'cancel' 
                        class = 'btn-primary'
                        invisible="status == 'Cancel'"/>


                        
                </header>

                    <sheet>

                        <group>
                            <field name="name"/>
                            <field name="author"/>
                            <field name="publisher"/>
                            <field name="category"/>
                            <field name="ISBN"/>
                            <field name="price"/>
                            <field name="language"/>
                            <field name="available_copies"/>
