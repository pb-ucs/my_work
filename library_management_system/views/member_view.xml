    <!-- FORM VIEW -->
    <record id="view_library_member_form" model="ir.ui.view">
        <field name="name">library.member.form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <header>
                   <button 
                    name = 'details' 
                    type = 'object' 
                    string = 'send email' 
                    class = 'btn-primary'/>

                   <button 
                    name = 'test' 
                    type = 'object' 
                    string = 'send test' 
                    class = 'btn-primary'/>
                </header>
                <sheet>
                    <group>
                       <field name="name"/>
                        <field name="member_code"/>
                        <!-- <field name="photo"/> -->
                        <field name="dob"/>
                        <field name="gender"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="address"/>
                        <field name="about" groups="library_management_system.group_lms_admin"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_library_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
