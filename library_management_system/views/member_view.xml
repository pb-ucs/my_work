
 <odoo>

    <record id="view_library_member_list" model="ir.ui.view">
        <field name="name">library.member.list</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list >
                <field name="name"/>
                <field name="member_code"/>
                <!-- <field name="photo"/> -->
                <field name="dob"/>
                <field name="gender"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="address"/>
                <field name="about" groups="library_management_system.group_lms_admin"/>
            </list>
        </field>
    </record>

